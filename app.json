{
  "expo": {
    "name": "知拌",
    "slug": "zhiban",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/tabbar/users-active.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4ECB71"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zhiban.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/tabbar/users-active.png",
        "backgroundColor": "#4ECB71"
      },
      "package": "com.zhiban.app"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "zhiban"
  }
}
